{
  "name": "cc-tracker",
  "displayName": "CC Tracker — Claude Code Usage",
  "description": "Shows Claude Code token usage for the active 5-hour limit window and the time until it resets.",
  "version": "0.2.0",
  "publisher": "MrN-studio",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MrNovoseltsev/cc-tracker.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "tokens",
    "usage",
    "ai"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cc-tracker.refresh",
        "title": "CC Tracker: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "cc-tracker.openPanel",
        "title": "CC Tracker: Open Panel"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ccTracker",
          "title": "CC Tracker",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "ccTracker": [
        {
          "id": "ccTracker.panel",
          "name": "Token Usage",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "cc-tracker.refresh",
          "when": "view == ccTracker.panel",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "CC Tracker",
      "properties": {
        "ccTracker.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the .claude directory. Empty = auto-detect (~/.claude)."
        },
        "ccTracker.refreshIntervalSec": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "description": "Local recompute interval, in seconds (a safety net for the file watcher)."
        },
        "ccTracker.statusBarWidth": {
          "type": "number",
          "default": 10,
          "minimum": 5,
          "maximum": 30,
          "description": "Number of circles in the status bar gauge. 10 = a 10% step per circle."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "node esbuild.js --production",
    "compile-tests": "tsc -p tsconfig.test.json",
    "test": "npm run compile-tests && node --test out-tests/test",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
