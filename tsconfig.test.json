{
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "target": "ES2022",
    "lib": ["ES2022"],
    "outDir": "out-tests",
    "rootDir": "src",
    "sourceMap": false,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/types.ts",
    "src/format.ts",
    "src/blockCalculator.ts",
    "src/limitEstimator.ts",
    "src/session.ts",
    "src/usageReader.ts",
    "src/usageApi.ts",
    "src/test/**/*.ts"
  ]
}
